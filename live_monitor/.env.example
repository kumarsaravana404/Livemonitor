# Copy this file to .env and fill in your real values
# NEVER commit the .env file — it's listed in .gitignore
#
# Generate a secure API key:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Required ──────────────────────────────────────────────────────────────────
SECUREWATCH_API_KEY=change-this-to-a-strong-random-key

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_PORT=5001
# Set to "development" to bypass API key check during local dev only
FLASK_ENV=production

# ── Data ──────────────────────────────────────────────────────────────────────
MAX_HISTORY=500
DB_FILE=securewatch.db

# ── Geo-IP ────────────────────────────────────────────────────────────────────
GEO_API_URL=https://ipapi.co/{ip}/json/
GEO_CACHE_TTL=3600
GEO_FAIL_TTL=60

# ── Security ──────────────────────────────────────────────────────────────────
# Set to your exact frontend domain in production (no trailing slash)
# Example: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*
