# ─────────────────────────────────────────────
# SecureWatch — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# REQUIRED: Change this to a long random string
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# Database path (Docker uses /data/securewatch.db)
DATABASE_PATH=securewatch.db

# Port to run on
PORT=8000

# OPTIONAL: Get a free token at https://ipinfo.io/signup
# Without this, geolocation will show "Unknown"
IPINFO_TOKEN=

# Allowed CORS origins (comma-separated, * = all)
ALLOWED_ORIGINS=*

# Auto-block settings
MAX_ATTEMPTS=5          # Block IP after this many failed attempts
BLOCK_HOURS=24          # How many hours to keep an IP blocked

# Flask environment
FLASK_ENV=production    # Use "development" for debug mode
